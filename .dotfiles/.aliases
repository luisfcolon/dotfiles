#!/usr/bin/env bash

# Managing dotfiles
alias showalias="vim $HOME/.dotfiles/.aliases"
alias srcalias="source $HOME/.dotfiles/.aliases"

# Misc
alias afk="/System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend"
alias hosts="sudo vim /etc/hosts"
alias flushdns="sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder"
alias cleanup="find . -type f -name '*.DS_Store' -ls -delete"
alias path='echo -e ${PATH//:/\\n}'
alias pubkey="cat $HOME/.ssh/id_rsa.pub | pbcopy | printf 'Public key copied to clipboard.\n'"
alias grep='grep --color=auto'
alias uuidgen='uuidgen | tr "[:upper:]" "[:lower:]"'
alias isodate="date +%Y-%m-%dT%H:%M:%S%z"
alias dirs="ls -lF -G | grep --color=never '^d'"
alias reload="exec ${SHELL} -l"

# Projects
alias w="cd $HOME/Workspace"
alias p="cd $HOME/Workspace/projects"

# Homebrew
alias brewup='brew upgrade; brew cleanup; brew doctor'

# Utilities
alias diskspace='du -shc .??* *'
alias emptytrash="sudo rm -rfv /Volumes/*/.Trashes; sudo rm -rfv $HOME/.Trash; sudo rm -rfv /private/var/log/asl/*.asl; sqlite3 $HOME/Library/Preferences/com.apple.LaunchServices.QuarantineEventsV* 'delete from LSQuarantineEvent'"
